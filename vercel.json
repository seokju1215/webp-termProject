{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "includeFiles": [
          "public/**",
          "db/**",
          "routes/**",
          "middleware/**",
          "uploads/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
